NODE_ENV=development
PORT=3000
# Production (e.g. Fly): set DATABASE_URL via `fly postgres attach` or fly secrets — overrides the vars below.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_USER=app
DATABASE_PASSWORD=app
DATABASE_NAME=timesheets_dev
JWT_ACCESS_SECRET=local-access-secret-change-me
JWT_REFRESH_SECRET=local-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
# Local dev: Vite port. Production (API + UI on Fly): your public app URL, e.g. https://<app>.fly.dev
WEB_ORIGIN=http://localhost:5173
